# ==============================================================================
# Laravel Application Configuration
# ==============================================================================
# Application-level settings for Laravel
# Docker infrastructure settings are in .env.docker
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================

APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ==============================================================================
# LOGGING
# ==============================================================================

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ==============================================================================
# DATABASE - POSTGRESQL (Docker Container)
# ==============================================================================

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# PostgreSQL Admin (pgAdmin)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ==============================================================================
# DATABASE - MYSQL (Optional - Uncomment to use)
# ==============================================================================

# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=laravel
# DB_PASSWORD=secret
# DB_ROOT_PASSWORD=root_secret

# ==============================================================================
# DATABASE - MONGODB (Optional)
# ==============================================================================

# MONGODB_HOST=mongodb
# MONGODB_PORT=27017
# MONGODB_DATABASE=laravel
# MONGODB_USERNAME=root
# MONGODB_PASSWORD=secret

# ==============================================================================
# SESSION & CACHE
# ==============================================================================

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=laravel_cache

# ==============================================================================
# REDIS (Docker Container)
# ==============================================================================

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=redis_password
REDIS_PORT=6379
REDIS_DB=0

# Redis Cache Database
REDIS_CACHE_DB=1

# Redis Queue Database
REDIS_QUEUE_DB=2

# ==============================================================================
# QUEUE & JOBS
# ==============================================================================

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

# ==============================================================================
# BROADCASTING
# ==============================================================================

BROADCAST_CONNECTION=reverb

# ==============================================================================
# FILESYSTEM & STORAGE
# ==============================================================================

FILESYSTEM_DISK=local

# MinIO S3-Compatible Storage (Docker Container)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laravel
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/laravel

# ==============================================================================
# MAIL (Docker Container - Mailpit)
# ==============================================================================

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# SEARCH - MEILISEARCH (Docker Container)
# ==============================================================================

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKeySecure123456

# ==============================================================================
# SEARCH - ELASTICSEARCH (Optional)
# ==============================================================================

# ELASTICSEARCH_HOST=http://elasticsearch:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=elastic

# ==============================================================================
# WEBSOCKETS - LARAVEL REVERB (Docker Container)
# ==============================================================================

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=reverb
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ==============================================================================
# MESSAGE BROKER - KAFKA (Optional)
# ==============================================================================

# KAFKA_BROKERS=kafka:9092
# KAFKA_CONSUMER_GROUP_ID=laravel
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SASL_MECHANISMS=

# ==============================================================================
# MESSAGE BROKER - RABBITMQ (Optional)
# ==============================================================================

# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# ==============================================================================
# VITE
# ==============================================================================

VITE_APP_NAME="${APP_NAME}"

# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================

# Add your third-party service credentials here
# STRIPE_KEY=
# STRIPE_SECRET=
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
