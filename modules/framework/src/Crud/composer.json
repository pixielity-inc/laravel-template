{
  "name": "pixielity/laravel-crud",
  "description": "CRUD operations and repository pattern implementation",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "crud",
    "repository",
    "pattern",
    "laravel",
    "pixielity"
  ],
  "authors": [
    {
      "name": "Pixielity Team",
      "email": "dev@pixielity.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5",
    "prettus/l5-repository": "@dev",
    "pixielity/laravel-database": "*"
  },
  "autoload": {
    "psr-4": {
      "Pixielity\\Crud\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pixielity\\Crud\\Providers\\CrudServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://gitlab.com/pixielity/laravel/framework/crud",
  "support": {
    "issues": "https://gitlab.com/pixielity/laravel/framework/crud/-/issues",
    "source": "https://gitlab.com/pixielity/laravel/framework/crud"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
