{
  "name": "pixielity/laravel-database",
  "description": "Database utilities and extensions for Laravel",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "database",
    "eloquent",
    "query-builder",
    "laravel",
    "pixielity"
  ],
  "authors": [
    {
      "name": "Pixielity Team",
      "email": "dev@pixielity.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "pixielity/laravel-support": "*",
    "illuminate/database": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Pixielity\\Database\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pixielity\\Database\\Providers\\DatabaseServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
