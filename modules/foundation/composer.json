{
    "name": "pixielity/foundation",
    "description": "Foundation module for Pixielity Laravel headless API backend - provides custom Application class, root route handlers, and base API structure",
    "type": "library",
    "keywords": [
        "laravel",
        "module",
        "foundation",
        "api",
        "headless",
        "pixielity"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Pixielity Inc",
            "email": "hello@pixielity.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/foundation": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pixielity\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixielity\\Foundation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pixielity\\Foundation\\Providers\\FoundationServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
