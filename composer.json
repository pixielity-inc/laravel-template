{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "pixielity/laravel-template",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "nwidart/laravel-modules": "^13.0",
        "predis/predis": "^3.4",
        "pixielity/laravel-framework": "@dev",
        "pixielity/laravel-foundation": "@dev"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.1",
        "driftingly/rector-laravel": "^2.2",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "nunomaduro/phpinsights": "^2.14",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5.12",
        "rector/rector": "^2.3",
        "spatie/laravel-ignition": "^2.12",
        "spatie/laravel-ray": "^1.43"
    },
    "scripts": {
        "setup": [
            "@setup:env",
            "@docker:up",
            "composer install",
            "php artisan key:generate --ansi",
            "php artisan migrate --force --ansi"
        ],
        "setup:env": [
            "php bin/setup-env"
        ],
        "setup:quick": [
            "composer install",
            "php bin/setup-env",
            "php artisan key:generate --ansi"
        ],
        "docker:up": [
            "docker-compose -f docker/docker-compose.yml up -d"
        ],
        "docker:down": [
            "docker-compose -f docker/docker-compose.yml down"
        ],
        "docker:restart": [
            "docker-compose -f docker/docker-compose.yml restart"
        ],
        "docker:logs": [
            "docker-compose -f docker/docker-compose.yml logs -f"
        ],
        "docker:ps": [
            "docker-compose -f docker/docker-compose.yml ps"
        ],
        "docker:build": [
            "docker-compose -f docker/compose.app.yml build --no-cache app"
        ],
        "docker:clean": [
            "docker-compose -f docker/docker-compose.yml down -v --remove-orphans"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "php artisan serve"
        ],
        "dev:octane": [
            "Composer\\Config::disableProcessTimeout",
            "php artisan octane:start --server=frankenphp --watch"
        ],
        "dev:full": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan octane:start --server=frankenphp --watch\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" --names=octane,queue,logs --kill-others"
        ],
        "octane": [
            "Composer\\Config::disableProcessTimeout",
            "php artisan octane:start --server=frankenphp --watch"
        ],
        "octane:prod": [
            "php artisan config:cache",
            "php artisan route:cache",
            "php artisan event:cache",
            "php artisan octane:start ----server=frankenphp --host=0.0.0.0 --port=8000"
        ],
        "octane:reload": [
            "php artisan octane:reload"
        ],
        "octane:stop": [
            "php artisan octane:stop"
        ],
        "optimize": [
            "php artisan config:cache",
            "php artisan route:cache",
            "php artisan event:cache"
        ],
        "optimize:clear": [
            "php artisan config:clear",
            "php artisan route:clear",
            "php artisan event:clear",
            "php artisan cache:clear"
        ],
        "test": [
            "php artisan config:clear --ansi",
            "php artisan test"
        ],
        "format": [
            "vendor/bin/pint"
        ],
        "format:test": [
            "vendor/bin/pint --test"
        ],
        "refactor": [
            "vendor/bin/rector process"
        ],
        "refactor:dry": [
            "vendor/bin/rector process --dry-run"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=512M"
        ],
        "analyse:baseline": [
            "vendor/bin/phpstan analyse --memory-limit=512M --generate-baseline"
        ],
        "insights": [
            "vendor/bin/phpinsights analyse --no-interaction"
        ],
        "insights:fix": [
            "vendor/bin/phpinsights analyse --fix --no-interaction"
        ],
        "quality": [
            "@format",
            "@refactor:dry",
            "@analyse"
        ],
        "quality:fix": [
            "@format",
            "@refactor",
            "@analyse"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "php bin/setup-env"
        ],
        "post-create-project-cmd": [
            "php bin/setup-env",
            "php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "composer-attribute-collector": {
            "include": [
                "{vendor}/pixielity/laravel-framework/src/*/src",
                "{vendor}/pixielity/laravel-foundation/src/Controllers",
                "{vendor}/pixielity/laravel-foundation/src/Concerns",
                "{vendor}/pixielity/laravel-foundation/src/Contracts",
                "{vendor}/pixielity/laravel-foundation/src/Traits",
                "modules/framework/src/*/src",
                "modules/foundation/src/Controllers"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./modules/*"
        }
    ],
    "autoload": {
        "files": [
            "vendor/attributes.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "olvlvl/composer-attribute-collector": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
